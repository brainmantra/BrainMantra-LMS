# Copy this file to api/.env and fill in real values.
# api/.env is git-ignored and must NEVER be committed.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection URL. Examples:
#   Local:   postgresql://postgres:password@localhost:5432/abacus100
#   Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#   Railway:  postgresql://postgres:[password]@[host]:5432/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/abacus100

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:5173

# ── Google Sheet (registration source of truth) ───────────────────────────────
# Publish your Google Form response sheet as CSV:
#   Sheet → File → Share → Publish to web → choose "Comma-separated values (.csv)" → Publish
# Paste the published URL here. It looks like:
#   https://docs.google.com/spreadsheets/d/e/XXXXXX/pub?output=csv
REGISTRATION_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv

# Column name in the sheet that holds the student's 10-digit mobile number.
# Adjust to match your form's actual column header exactly (case-sensitive).
SHEET_MOBILE_COLUMN=Mobile Number

# Column name for the student's name.
SHEET_NAME_COLUMN=Full Name

# Column name for the level (must match one of: beginner,elementary,intermediate,advanced,expert).
SHEET_LEVEL_COLUMN=Level
